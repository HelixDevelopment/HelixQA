  "test_cases": [
    {
      "id": "FQA-XP-001",
      "name": "Login credentials work across all platforms",
      "category": "cross-platform",
      "priority": "critical",
      "platforms": [
        "api",
        "web",
        "androidtv",
        "android"
      ],
      "steps": [
        {
          "name": "Login via API",
          "action": "http: POST /api/v1/auth/login",
          "expected": "200 OK with session token",
          "auth": "admin",
          "_original_action": "POST /api/v1/auth/login with admin/admin123",
          "expect_status": 200
        },
        {
          "name": "Login via Web",
          "action": "Navigate to login page, enter admin/admin123, click Login",
          "expected": "Redirects to dashboard",
          "_conversion_note": "manual-review-required"
        },
        {
          "name": "Login via Android TV",
          "action": "Launch app, configure server, enter admin/admin123",
          "expected": "Navigates to home screen",
          "_conversion_note": "manual-review-required"
        },
        {
          "name": "Login via Android Phone",
          "action": "Launch app, configure server, enter admin/admin123",
          "expected": "Navigates to home screen",
          "_conversion_note": "manual-review-required"
        }
      ],
      "tags": [
        "cross-platform",
        "auth",
        "login"
      ],
      "estimated_duration": "60s",
      "expected_result": "Same credentials authenticate on all platforms"
    },
