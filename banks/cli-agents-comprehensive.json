    {
      "id": "CLI-REG-001",
      "name": "Agent registry initialization",
      "category": "functional",
      "priority": "critical",
      "platforms": [
        "api",
        "cli"
      ],
      "steps": [
        {
          "name": "Initialize agent registry",
          "action": "Create new Registry instance",
          "expected": "Registry created with empty agents map"
        },
        {
          "name": "Check initial stats",
          "action": "Call registry.GetStats()",
          "expected": "Returns total: 0, available: 0, started: 0"
        }
      ],
      "tags": [
        "registry",
        "initialization"
      ],
      "estimated_duration": "5s",
      "expected_result": "Registry initializes successfully"
    },
    {
      "id": "CLI-REG-002",
      "name": "Register all 47 agents",
      "category": "functional",
      "priority": "critical",
      "platforms": [
        "api",
        "cli"
      ],
      "steps": [
        {
          "name": "Get global registry",
          "action": "Call agents.GetGlobalRegistry()",
          "expected": "Returns singleton registry instance"
        },
        {
          "name": "Register each agent",
          "action": "Iterate through AllAgentTypes() and register each",
          "expected": "All agents registered without errors"
        },
        {
          "name": "Verify registration count",
          "action": "Check registry.GetStats()['total']",
          "expected": "Equals 47 (or more if additional agents)"
