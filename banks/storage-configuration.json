    {
      "id": "STOR-WDV-001",
      "name": "WebDAV: configure and connect successfully",
      "category": "functional",
      "priority": "critical",
      "platforms": [
        "android",
        "desktop"
      ],
      "steps": [
        {
          "name": "Open storage settings",
          "action": "Navigate to Settings > Storage Protocols",
          "expected": "Storage configuration screen visible",
          "_conversion_note": "manual-review-required"
        },
        {
          "name": "Select WebDAV",
          "action": "Tap/click 'Add WebDAV server'",
          "expected": "WebDAV configuration form displayed",
          "_conversion_note": "manual-review-required"
        },
        {
          "name": "Enter server URL",
          "action": "Type 'https://dav.example.com/remote.php/dav/files/user/'",
          "expected": "URL field shows entered value",
          "_conversion_note": "manual-review-required"
        },
        {
          "name": "Enter credentials",
          "action": "Enter username 'testuser' and password 'testpass123'",
          "expected": "Credentials accepted",
          "_conversion_note": "manual-review-required"
        },
        {
          "name": "Test connection",
          "action": "Tap/click 'Test Connection' button",
          "expected": "Progress indicator shown, then green success indicator",
          "_conversion_note": "manual-review-required"
        },
        {
          "name": "Save configuration",
          "action": "Tap/click 'Save'",
          "expected": "WebDAV server appears in storage list",
          "_conversion_note": "manual-review-required"
        }
      ],
      "tags": [
        "webdav",
        "configuration",
        "connection",
        "success"
      ],
      "documentation_refs": [
        {
          "type": "user_guide",
          "section": "5.1",
          "path": "docs/USER_MANUAL_DESKTOP.md"
        }
      ],
      "estimated_duration": "45s",
      "expected_result": "WebDAV server configured and accessible in storage list"
    },
