{
  "version": "1.0",
  "name": "CLI Agents as HelixAgent System Validators",
  "description": "47 CLI agents test HelixAgent using their native capabilities with exported configs",
  "metadata": {
    "author": "vasic-digital",
    "app": "HelixAgent",
    "version": "1.0.0",
    "validation_strategy": "cli_agents_as_testers",
    "config_source": "exported_helixagent_configs",
    "agents_total": 47
  },
  "test_cases": [
    {
      "id": "CLI-CC-001",
      "name": "Claude Code validates HelixAgent via terminal integration",
      "category": "system_validation",
      "priority": "critical",
      "executor_agent": "claude_code",
      "config_file": "cli_agents_configs/claude-code.yaml",
      "helixagent_features_tested": [
        "ensemble_api",
        "mcp_tools",
        "streaming",
        "debate_orchestrator"
      ],
      "steps": [
        {
          "name": "Load exported HelixAgent config",
          "action": "--config=/etc/helixagent/agents/claude-code.yaml",
          "expected": "Config loaded with HelixAgent endpoint, API key, model preferences"
        },
        {
          "name": "Test ensemble via natural chat",
          "action": "Chat: 'Use HelixAgent ensemble to explain Go interfaces'",
          "expected": "Claude Code routes to HelixAgent /v1/ensemble/completions, shows aggregated response"
        },
        {
          "name": "Verify multi-provider aggregation",
          "action": "Ask: 'Show me which providers contributed'",
          "expected": "Response metadata shows Claude, DeepSeek, Gemini contributions"
        },
        {
          "name": "Test MCP tools through chat",
          "action": "Chat: 'Read the HelixAgent README'",
          "expected": "Claude Code uses MCP read_file tool via HelixAgent MCP bridge"
        },
        {
          "name": "Validate streaming in terminal",
          "action": "Request streaming completion",
          "expected": "Real-time token streaming visible in terminal UI"
        },
        {
          "name": "Test debate mode",
          "action": "Chat: 'Debate: Should we use Redis or PostgreSQL for sessions?'",
          "expected": "HelixAgent debate orchestrator activated, multiple viewpoints shown"
        }
      ],
      "tags": [
        "claude_code",
        "terminal",
        "ensemble",
        "mcp",
        "debate"
      ],
      "estimated_duration": "120s",
      "expected_result": "Claude Code validates all HelixAgent features through natural terminal interaction"
    },
