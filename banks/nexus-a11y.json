{
  "name": "Helix Nexus \u2014 Accessibility",
  "description": "Bank covering axe-core integration, WCAG A/AA/AAA assertion, Section 508 filter, and injection script vendoring.",
  "metadata": {
    "feature": "helix-nexus-a11y",
    "phase": 5
  },
  "test_cases": [
    {
      "id": "NX-A11Y-001",
      "name": "Parse empty axe output errors",
      "category": "functional",
      "priority": "high",
      "platforms": [
        "web-nexus"
      ],
      "steps": [
        {
          "name": "Parse(nil)",
          "action": "a11y.Parse",
          "expected": "error: empty axe output"
        }
      ],
      "expected_result": "No silent empty parse"
    },
    {
      "id": "NX-A11Y-002",
      "name": "Level A fails on critical",
      "category": "functional",
      "priority": "critical",
      "platforms": [
        "web-nexus"
      ],
      "steps": [
        {
          "name": "Assert(LevelA) on report with critical violation",
          "action": "Report.Assert",
          "expected": "error names the violation id"
        }
      ],
      "expected_result": "Critical breaches always flagged"
    },
    {
      "id": "NX-A11Y-003",
      "name": "Level AA fails on serious",
      "category": "functional",
      "priority": "critical",
      "platforms": [
        "web-nexus"
      ],
      "steps": [
        {
          "name": "Assert",
          "action": "Report.Assert(LevelAA)",
          "expected": "error names serious rule"
        }
      ],
      "expected_result": "Serious breaches surface at AA"
    },
    {
      "id": "NX-A11Y-004",
      "name": "Level AAA fails on moderate",
      "category": "functional",
      "priority": "high",
      "platforms": [
        "web-nexus"
      ],
      "steps": [
        {
          "name": "Assert",
          "action": "Report.Assert(LevelAAA)",
          "expected": "error includes moderate rule"
        }
      ],
      "expected_result": "AAA catches moderate"
    },
    {
      "id": "NX-A11Y-005",
      "name": "Clean report passes all levels",
      "category": "functional",
      "priority": "medium",
      "platforms": [
        "web-nexus"
      ],
      "steps": [
        {
          "name": "Assert",
          "action": "empty Report.Assert(LevelAAA)",
          "expected": "nil"
        }
      ],
      "expected_result": "Happy path green"
    },
    {
      "id": "NX-A11Y-006",
      "name": "Section508 filter returns subset",
      "category": "functional",
      "priority": "medium",
      "platforms": [
        "web-nexus"
      ],
      "steps": [
        {
          "name": "Filter",
          "action": "Report.Section508",
          "expected": "only violations tagged section508"
        }
      ],
      "expected_result": "Compliance reports scoped"
    },
    {
      "id": "NX-A11Y-007",
      "name": "Unknown level rejected",
      "category": "security",
      "priority": "medium",
      "platforms": [
        "web-nexus"
      ],
      "steps": [
        {
          "name": "Assert",
          "action": "Report.Assert('Z')",
          "expected": "error"
        }
      ],
      "expected_result": "Guard against typos"
    },
    {
      "id": "NX-A11Y-008",
      "name": "Injection script includes vendored path",
      "category": "security",
      "priority": "high",
      "platforms": [
        "web-nexus"
      ],
      "steps": [
        {
          "name": "Script",
          "action": "InjectionScript('https://cdn/x')",
          "expected": "contains https://cdn/x/axe.min.js"
        }
      ],
      "expected_result": "No CDN fetch allowed"
    },
    {
      "id": "NX-A11Y-009",
      "name": "Summary maps all severities",
      "category": "functional",
      "priority": "low",
      "platforms": [
        "web-nexus"
      ],
      "steps": [
        {
          "name": "Summary",
          "action": "Report.Summary",
          "expected": "keys minor/moderate/serious/critical all present"
        }
      ],
      "expected_result": "Summary stable"
    },
    {
      "id": "NX-A11Y-010",
      "name": "Nil receiver Assert returns error",
      "category": "functional",
      "priority": "low",
      "platforms": [
        "web-nexus"
      ],
      "steps": [
        {
          "name": "Assert",
          "action": "(*Report)(nil).Assert(LevelAA)",
          "expected": "error"
        }
      ],
      "expected_result": "Nil-safe"
    },
    {
      "id": "NX-A11Y-011",
      "name": "Auditor.RunAndAssert green path against demo page",
      "category": "functional",
      "priority": "critical",
      "platforms": [
        "web-nexus"
      ],
      "tags": [
        "a11y",
        "auditor",
        "e2e",
        "fixes-validation"
      ],
      "steps": [
        {
          "name": "Open demo page",
          "action": "browser.Open https://demo.test/accessible.html",
          "expected": "Session opened with Elements > 0"
        },
        {
          "name": "auditor := NewAuditor(vendoredAxePath, LevelAA)",
          "action": "a11y.NewAuditor",
          "expected": "non-nil Auditor"
        },
        {
          "name": "auditor.RunAndAssert(ctx, browserEvaluator)",
          "action": "a11y.Auditor.RunAndAssert",
          "expected": "nil error AND Report.Summary has zero critical/serious violations"
        }
      ],
      "expected_result": "Green E2E \u2014 confirms the axe-core injection, Evaluator.Eval, Parse, and level assertion chain all wired together"
    },
    {
      "id": "NX-A11Y-012",
      "name": "Auditor.RunAndAssert fails on seeded critical violation",
      "category": "functional",
      "priority": "critical",
      "platforms": [
        "web-nexus"
      ],
      "tags": [
        "a11y",
        "auditor",
        "e2e",
        "fixes-validation"
      ],
      "steps": [
        {
          "name": "Open seeded-violation page (<img src=x>)",
          "action": "browser.Open https://demo.test/broken.html",
          "expected": "Page loaded"
        },
        {
          "name": "auditor.RunAndAssert(ctx, browserEvaluator)",
          "action": "a11y.Auditor.RunAndAssert",
          "expected": "non-nil error naming the missing-alt rule"
        }
      ],
      "expected_result": "Critical violations surface at LevelAA \u2014 regression guard for W9"
    },
    {
      "id": "NX-A11Y-013",
      "name": "Auditor.RunAndAssert surfaces Evaluator errors",
      "category": "functional",
      "priority": "high",
      "platforms": [
        "web-nexus"
      ],
      "tags": [
        "a11y",
        "auditor",
        "error-path"
      ],
      "steps": [
        {
          "name": "Pass evaluator that returns error",
          "action": "a11y.Auditor.RunAndAssert(ctx, failingEvaluator)",
          "expected": "error wrapping 'eval axe: ...'"
        }
      ],
      "expected_result": "Evaluator failures bubble up unchanged"
    }
  ]
}