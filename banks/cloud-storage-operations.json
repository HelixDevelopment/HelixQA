      "category": "functional",
      "priority": "high",
      "platforms": [
        "android",
        "desktop"
      ],
      "steps": [
        {
          "name": "Cause repeated connection failures",
          "action": "Configure WebDAV with unreachable server, attempt 5 operations",
          "expected": "First few attempts show connection errors",
          "_conversion_note": "manual-review-required"
        },
        {
          "name": "Verify circuit breaker opens",
          "action": "Attempt another operation",
          "expected": "Circuit breaker open message: 'Service temporarily unavailable'",
          "_conversion_note": "manual-review-required"
        },
        {
          "name": "Wait for half-open state",
          "action": "sleep: 30000",
          "expected": "Circuit breaker allows one probe request",
          "_original_action": "Wait 30 seconds"
        },
        {
          "name": "Restore server and probe",
          "action": "Fix server config, attempt operation",
          "expected": "Circuit breaker closes; normal operation resumes",
          "_conversion_note": "manual-review-required"
        }
      ],
      "tags": [
        "cloud",
        "circuit-breaker",
        "resilience",
        "webdav"
      ],
      "estimated_duration": "90s",
      "expected_result": "Circuit breaker opens on failures and closes on recovery"
