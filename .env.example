# HelixQA Autonomous QA Session Configuration
# Copy to .env and fill in values.

# ─── Master Switch ───────────────────────────────────────
HELIX_AUTONOMOUS_ENABLED=true
HELIX_AUTONOMOUS_PLATFORMS=android,desktop,web
HELIX_AUTONOMOUS_TIMEOUT=2h
HELIX_AUTONOMOUS_COVERAGE_TARGET=0.90
HELIX_AUTONOMOUS_CURIOSITY_ENABLED=true
HELIX_AUTONOMOUS_CURIOSITY_TIMEOUT=30m

# ─── LLMsVerifier ───────────────────────────────────────
LLMSVERIFIER_CONFIG=./llmsverifier.yaml
LLMSVERIFIER_STRATEGY=helix-qa
LLMSVERIFIER_MIN_SCORE=0.6
LLMSVERIFIER_MAX_MODELS=5
LLMSVERIFIER_CACHE_RESULTS=true
LLMSVERIFIER_CACHE_TTL=24h

# ====== Distributed Vision Hosts ======
# Comma-separated list of hosts for distributed llama.cpp RPC.
# Each host runs Ollama or llama.cpp for vision processing.
# Leave empty to use single-host mode (HELIX_VISION_HOST).
HELIX_VISION_HOSTS=thinker.local,amber.local
HELIX_VISION_MULTI_USER=milosvasic
# Model path on hosts for llama.cpp RPC
HELIX_LLAMACPP_RPC_MODEL=~/models/vision-model.gguf

# ====== Vision Providers ======
# Astica.AI Vision (highest quality specialized vision)
ASTICA_API_KEY=YOUR_ASTICA_API_KEY_HERE

# Cloud vision providers
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
KIMI_API_KEY=YOUR_KIMI_KEY_HERE
STEPFUN_API_KEY=YOUR_STEPFUN_KEY_HERE
NVIDIA_API_KEY=YOUR_NVIDIA_KEY_HERE

# Additional cloud providers (optional)
GROQ_API_KEY=YOUR_GROQ_KEY_HERE
MISTRAL_API_KEY=YOUR_MISTRAL_KEY_HERE
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY_HERE
XAI_API_KEY=YOUR_XAI_KEY_HERE
TOGETHER_API_KEY=YOUR_TOGETHER_KEY_HERE
QWEN_API_KEY=YOUR_QWEN_KEY_HERE
JUNIE_API_KEY=YOUR_JUNIE_KEY_HERE

# Local vision (Ollama)
HELIX_OLLAMA_URL=http://thinker.local:11434
HELIX_OLLAMA_MODEL=minicpm-v:8b

# ====== Chat Models (for reasoning/planning) ======
# These are used for test planning and report generation.
# Vision providers above can also handle chat if they support it.
# The system uses a dual-model architecture:
#   - Vision models: analyze screenshots (Astica, Gemini, OpenAI, Ollama)
#   - Chat models: generate test plans, write reports, reason about findings

# ─── CLI Agents ─────────────────────────────────────────
HELIX_AGENTS_ENABLED=opencode,claude-code,gemini
HELIX_AGENT_OPENCODE_PATH=/usr/local/bin/opencode
HELIX_AGENT_CLAUDE_PATH=/usr/local/bin/claude
HELIX_AGENT_GEMINI_PATH=/usr/local/bin/gemini
HELIX_AGENT_JUNIE_PATH=/usr/local/bin/junie
HELIX_AGENT_QWEN_PATH=/usr/local/bin/qwen-code
HELIX_AGENT_TIMEOUT=60s
HELIX_AGENT_MAX_RETRIES=3
HELIX_AGENT_POOL_SIZE=3

# ─── Vision Engine ──────────────────────────────────────
# Provider selection: auto, astica, openai, anthropic, gemini, ollama, etc.
# "auto" dynamically probes all configured providers and selects the best.
HELIX_VISION_PROVIDER=auto
HELIX_VISION_OPENCV_ENABLED=true
HELIX_VISION_SSIM_THRESHOLD=0.95
HELIX_VISION_MAX_IMAGE_SIZE=4096

# ─── Doc Processor ──────────────────────────────────────
HELIX_DOCS_ROOT=./docs
HELIX_DOCS_AUTO_DISCOVER=true
HELIX_DOCS_FORMATS=md,yaml,html,adoc,rst

# ─── Recording ──────────────────────────────────────────
HELIX_RECORDING_VIDEO=true
HELIX_RECORDING_SCREENSHOTS=true
HELIX_RECORDING_VIDEO_QUALITY=medium
HELIX_RECORDING_SCREENSHOT_FORMAT=png
HELIX_RECORDING_FFMPEG_PATH=/usr/bin/ffmpeg

# ─── Audio Recording ───────────────────────────────────
# Set to true to enable audio capture during test execution.
# Useful for detecting audio reproduction problems (glitches,
# dropouts, distortion).
HELIXQA_RECORDING_AUDIO=false
HELIXQA_RECORDING_AUDIO_QUALITY=high
HELIXQA_RECORDING_AUDIO_FORMAT=wav
HELIXQA_RECORDING_AUDIO_DEVICE=default

# ─── Platform-specific ──────────────────────────────────
HELIX_ANDROID_DEVICE=emulator-5554
HELIX_ANDROID_PACKAGE=com.example.app
HELIX_WEB_URL=http://localhost:8080
HELIX_WEB_BROWSER=chromium
HELIX_DESKTOP_PROCESS=yole-desktop
HELIX_DESKTOP_DISPLAY=:0

# ─── Output ─────────────────────────────────────────────
HELIX_OUTPUT_DIR=./qa-results
HELIX_REPORT_FORMATS=markdown,html,json
HELIX_TICKETS_ENABLED=true
HELIX_TICKETS_MIN_SEVERITY=low

# ─── Remote Vision Auto-Deploy ───────────────────────────
# HelixQA auto-ensures Ollama + vision model are running on
# this host before each session. Leave empty to disable.
HELIX_VISION_HOST=
HELIX_VISION_USER=
HELIX_VISION_MODEL=llava:7b

# Per-host model assignment (optional, defaults to HELIX_VISION_MODEL).
# Replace dots/hyphens in hostname with underscores for the env var key.
# HELIX_VISION_HOST_thinker_MODEL=minicpm-v:8b
# HELIX_VISION_HOST_amber_MODEL=llava:7b

# ─── Distributed llama.cpp RPC ───────────────────────────
# Split large models across multiple hosts using llama.cpp
# RPC protocol. Each worker contributes its VRAM/RAM to the
# inference pool. Requires llama.cpp built with -DGGML_RPC=ON.
HELIX_LLAMACPP_RPC_ENABLED=false
HELIX_LLAMACPP_RPC_WORKERS=

# ─── Device Exclusion ────────────────────────────────────
# Comma-separated model substrings to exclude from ADB testing
HELIX_ADB_EXCLUDE=ATMOSphere
